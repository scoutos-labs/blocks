{
  "name": "release",
  "version": 2,
  "protocol": 3,
  "notes": "Compose the changelog workflow, require a signed approval, then cut a release note. Composition + AAITL in one DAG.",
  "inputs": {
    "range": {
      "type": "string",
      "default": "HEAD~8..HEAD",
      "description": "git revision range for the changelog"
    }
  },
  "grants": {
    "run": [
      "git"
    ],
    "read": [
      "**"
    ],
    "write": [
      "CHANGELOG.md",
      "RELEASE.md"
    ]
  },
  "outputs": {
    "changelog": {
      "from": "{{nodes.changelog.output.changelog}}",
      "type": "string",
      "required": false
    },
    "released": {
      "from": "{{nodes.cut.output.path}}",
      "type": "string",
      "required": false
    }
  },
  "nodes": [
    {
      "id": "changelog",
      "workflow": "changelog-from-git@2",
      "notes": "the whole Draft-01 changelog pipeline, embedded as one node",
      "in": {
        "range": "{{inputs.range}}"
      }
    },
    {
      "id": "approve",
      "block": "approve-release@2",
      "when": "#nodes.changelog.output.changelog > 0 and nodes.changelog.output.changelog contains 'Changelog'",
      "notes": "authoritative gate: requires a key with the release-approver claim",
      "in": {
        "candidate": "{{nodes.changelog.output.changelog}}"
      }
    },
    {
      "id": "cut",
      "block": "write-file@1",
      "when": "nodes.approve.output.approved == true",
      "in": {
        "path": "RELEASE.md",
        "content": "# Release\n\napproved by {{nodes.approve.output.approver}} \u2014 {{nodes.approve.output.reason}}\n\n{{nodes.changelog.output.changelog}}"
      }
    }
  ]
}
