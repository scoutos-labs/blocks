{
  "name": "changelog-from-git",
  "version": 2,
  "protocol": 2,
  "notes": "Draft a changelog from the commit log, judge it against the log, publish only if it passes.",
  "inputs": {
    "range": {
      "type": "string",
      "default": "HEAD~15..HEAD",
      "description": "git revision range to summarize"
    }
  },
  "grants": {
    "run": [
      "git"
    ],
    "read": [
      "**"
    ],
    "write": [
      "CHANGELOG.md"
    ]
  },
  "outputs": {
    "changelog": {
      "from": "{{nodes.render.output.text}}",
      "type": "string",
      "required": false
    }
  },
  "nodes": [
    {
      "id": "log",
      "block": "git-log@2",
      "in": {
        "range": "{{inputs.range}}"
      }
    },
    {
      "id": "draft",
      "block": "summarize@1",
      "notes": "the oracle writes the changelog body from the raw log",
      "in": {
        "text": "{{nodes.log.output.text}}",
        "style": "markdown changelog grouped by change type (Features / Fixes / Docs / Internal), terse, user-facing, keep short hashes"
      }
    },
    {
      "id": "judge",
      "block": "llm-judge@1",
      "notes": "quality gate: the draft must be grounded in the log",
      "in": {
        "candidate": "{{nodes.draft.output.summary}}",
        "criteria": "Every entry traces to a commit in the log below \u2014 no invented changes. Grouped by change type. Terse and user-facing. Log:\n{{nodes.log.output.text}}"
      }
    },
    {
      "id": "render",
      "block": "render-template@1",
      "when": "nodes.judge.output.score >= 0.7 and nodes.judge.output.verdict == 'pass'",
      "in": {
        "template": "# Changelog\n\n_range: {range} \u2014 judged {score}_\n\n{body}\n",
        "values": {
          "range": "{{inputs.range}}",
          "score": "{{nodes.judge.output.score}}",
          "body": "{{nodes.draft.output.summary}}"
        }
      }
    },
    {
      "id": "publish",
      "block": "write-file@1",
      "in": {
        "path": "CHANGELOG.md",
        "content": "{{nodes.render.output.text}}"
      }
    }
  ]
}
