{
  "name": "write-file",
  "version": 1,
  "kind": "deterministic",
  "inputs": {
    "path": { "type": "string", "description": "workspace-relative destination" },
    "content": { "type": "string" }
  },
  "outputs": { "path": { "type": "string" }, "bytes": { "type": "number" } },
  "exec": { "entry": "run.mjs" },
  "permissions": { "run": [], "read": [], "write": ["**"], "network": false }
}
